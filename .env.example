# Neon PostgreSQL connection string (use the POOLED connection string from the Neon dashboard).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) connection — same host WITHOUT the `-pooler` suffix.
# Used only by `prisma migrate` (deploy/dev); the pooler can't hold migration advisory locks.
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"

# Only needed in some deployments; Vercel sets this automatically.
# AUTH_URL="https://your-app.vercel.app"

# Admin allowlist — comma-separated emails that may access /admin and the admin API
# (publish/edit/delete psychologist applications). Must match a registered account's email.
ADMIN_EMAILS="admin@example.com"

# Upstash Redis (free tier) — anti brute-force rate limiting on login/registration.
# Optional: if unset, rate limiting is disabled (the app still works). Create a free
# database at https://console.upstash.com and copy the REST URL + token here.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend (free tier) — appointment confirmation emails. Optional: if unset, emails are
# disabled (bookings still work). Get an API key at https://resend.com.
RESEND_API_KEY=""
# Sender address. Accepts a bare address ("x@y.com") or a named one ("Name <x@y.com>").
# Pick the option that matches your setup:
#   1) Leave EMPTY — falls back to the sandbox sender (onboarding@resend.dev). No domain
#      setup needed, but Resend only delivers to YOUR OWN account email. Good for a demo.
#   2) Own a domain — verify it in Resend (Dashboard > Domains, add the DNS records), then
#      set e.g. "Psychologists.Services <no-reply@yourdomain.com>" to reach ANY recipient.
# Resend will not deliver to arbitrary recipients from the sandbox sender (option 1).
EMAIL_FROM=""
