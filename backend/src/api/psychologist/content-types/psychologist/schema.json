    },
    "license": {
      "type": "string"
    },
    "specialization": {
      "type": "string"
    },
    "initial_consultation": {
      "type": "string"
    },
    "about": {
      "type": "text"
    },
    "rating": {
      "type": "decimal"
    },
    "price_per_hour": {
      "type": "decimal"
    },
    "popular": {
      "type": "boolean",
      "default": false
    },
    "reviews": {
      "type": "json"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "isAvailable": {
      "type": "boolean",
      "default": true
    },
    "favorited_by": {
